{
  "name": "eslint-config-mister-hope",
  "version": "0.11.1",
  "description": "eslint plugin for hope",
  "keywords": [
    "eslint",
    "eslint-config"
  ],
  "author": {
    "name": "Mister-Hope",
    "email": "mister-hope@outlook.com",
    "url": "https://mister-hope.com"
  },
  "repository": {
    "url": "https://github.com/Mister-Hope/eslint-config-mister-hope"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "type": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./vue": {
      "type": "./dist/vue.d.ts",
      "default": "./dist/vue.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf ./dist",
    "lint": "eslint . --fix && oxfmt",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@typescript-eslint/utils": "^8.61.1",
    "@vitest/eslint-plugin": "^1.6.20",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.16.2",
    "globals": "^17.6.0",
    "typescript-eslint": "^8.61.1"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.0",
    "@commitlint/config-conventional": "21.2.0",
    "@mr-hope/tsconfig": "0.0.4",
    "@types/node": "24.13.2",
    "husky": "9.1.7",
    "jiti": "2.7.0",
    "nano-staged": "1.0.2",
    "oxfmt": "0.56.0",
    "rimraf": "6.1.3",
    "tsdown": "0.22.3",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "eslint": "^10.0.0",
    "eslint-plugin-vue": "^10.2.0",
    "vue-eslint-parser": "^10.1.3"
  },
  "peerDependenciesMeta": {
    "eslint-plugin-vue": {
      "optional": true
    },
    "vue-eslint-parser": {
      "optional": true
    }
  },
  "nano-staged": {
    "**/*": "prettier --write --ignore-unknown",
    "*.{js,ts}": "eslint --fix"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.8.0",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": "^22.23.0 || ^24.16.0 || ^26.3.0",
      "onFail": "error"
    }
  },
  "engines": {
    "node": "^22.18.0 || ^24.0.0 || ^26.0.0"
  }
}
